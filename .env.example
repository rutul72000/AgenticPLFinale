PORT=8080
JWT_SECRET=replace-with-strong-secret
DEMO_USERNAME=security
DEMO_PASSWORD=admin123
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant
# AI budget controls (recommended for long demos)
AI_MAX_CALLS_PER_HOUR=60
AI_MIN_INTERVAL_MS=12000
# Keep false to conserve AI calls; fallback PA is still high quality
AI_ENABLE_INCIDENT_ANNOUNCEMENTS=false
ALLOWED_ORIGINS=
LOG_LEVEL=info
